  }

  public string GetDefaultLang(SILGlobals Globals)
  {
    if (Operators.CompareString(this.LangsOrgAllowed, string.Empty, false) == 0)
    {
      this.LangsOrgAllowed = "en";
      this.LangOrgDefault = this.LangsOrgAllowed;
      Globals.objDebug.Log(20, $"GetDefaultLang: No languages allowed for org; setting list to '{this.LangOrgDefault}'");
    }
    if (Operators.CompareString(this.LangOrgDefault, string.Empty, false) == 0 | !Globals.objUtility.ItemIsInString(this.LangsOrgAllowed, ',', this.LangOrgDefault))
    {
      this.LangOrgDefault = Globals.objUtility.TruncateToNItems(this.LangsOrgAllowed, ',', 1);
      Globals.objDebug.Log(20, $"GetOrgDefaultLang: Setting local copy of org default lang to '{this.LangOrgDefault}'");
    }
    return this.LangOrgDefault;
  }

